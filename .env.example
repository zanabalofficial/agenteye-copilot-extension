# AgentEye Copilot Extension — Configuration

# === REQUIRED ===
# Your OpenRouter API key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === AI MODEL ===
# Model to use for code review (any OpenRouter model)
AI_MODEL=anthropic/claude-sonnet-4

# === OPTIONAL ===
# API provider
AI_PROVIDER=openrouter

# Custom API endpoint (defaults to OpenRouter)
# AI_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Max tokens per review response
# AI_MAX_TOKENS=2048

# Temperature (lower = more consistent)
# AI_TEMPERATURE=0.3

# === SERVER ===
# Port to run the server on
# PORT=3000

# Host to bind to
# HOST=0.0.0.0

# === REVIEW ===
# Review focus areas (comma-separated)
# REVIEW_TYPES=bug,security,performance,style,architecture

# Max file size in characters
# MAX_FILE_SIZE=100000
